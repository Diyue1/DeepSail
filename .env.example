# DeepSail Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# Server Configuration
PORT=3000
NODE_ENV=development

# Amap (高德地图) API Key
# Get your key at: https://lbs.amap.com/
AMAP_KEY=your_amap_key_here

# ShipXY API Key (船讯网)
# Get your key at: https://www.shipxy.com/
SHIPXY_KEY=your_shipxy_key_here
